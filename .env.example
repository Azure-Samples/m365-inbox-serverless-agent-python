# Default provider: Microsoft Foundry with Entra ID identity (no keys).
# After `azd provision`, run scripts/hydrate-local-settings.sh to fill these in.
AZURE_FUNCTIONS_AGENTS_PROVIDER=foundry
FOUNDRY_PROJECT_ENDPOINT=https://<your-ai-services>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL=gpt-5.4-mini

# M365 connectors (blank = offline sample data; azd up wires these for deployed runs)
TO_EMAIL=you@example.com
OUTLOOK_MCP_ENDPOINT=
TEAMS_MCP_ENDPOINT=
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=

# Local Azurite + worker runtime
AzureWebJobsStorage=UseDevelopmentStorage=true
FUNCTIONS_WORKER_RUNTIME=python
