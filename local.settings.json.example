    "FOUNDRY_PROJECT_ENDPOINT": "<set from: azd env get-value FOUNDRY_PROJECT_ENDPOINT>",
    "FOUNDRY_MODEL": "gpt-5.4-mini",

    "MAILBOX_OWNER_EMAIL": "<your-mailbox@example.com>",
    "OUTLOOK_MCP_ENDPOINT": "",
    "TEAMS_MCP_ENDPOINT": "",
    "TEAMS_TEAM_ID": "",
    "TEAMS_CHANNEL_ID": ""
  }
}
